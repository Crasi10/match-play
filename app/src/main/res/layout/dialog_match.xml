<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC000000"
                android:padding="30dp">
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IT'S A MATCH!"
                android:textColor="@color/pitch_green"
                android:textSize="45sp"
                android:textStyle="italic|bold"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="10dp"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You and this team/player liked each other."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textAlignment="center"
                android:layout_marginBottom="50dp"/>

        <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnChatNow"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="SEND MESSAGE"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:layout_marginBottom="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnKeepSwiping"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="KEEP SWIPING"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="#00000000" /> </LinearLayout>
</RelativeLayout>