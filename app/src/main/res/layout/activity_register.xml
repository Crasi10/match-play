<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:padding="24dp"
              android:gravity="center"
              android:background="@color/bg_light">

    <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:backgroundTint="@color/pitch_green"
            android:textColor="#FFFFFF"
            android:layout_gravity="start"
            android:layout_marginBottom="20dp"/>

    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the Club"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/pitch_green"
            android:layout_marginBottom="32dp"/>

    <EditText
            android:id="@+id/inputName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Full Name / Team Name"
            android:inputType="textPersonName"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="16dp"/>

    <EditText
            android:id="@+id/inputEmail"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Email Address"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="16dp"/>

    <EditText
            android:id="@+id/inputPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="24dp"/>

    <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

        <RadioButton
                android:id="@+id/radioPlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/pitch_green"
                android:layout_marginEnd="24dp"/>

        <RadioButton
                android:id="@+id/radioTeam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/pitch_green"/>
    </RadioGroup>

    <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Sign Contract"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_primary"/>

</LinearLayout>