<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_light">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team Stats"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/pitch_green"
                android:layout_marginBottom="20dp"
                android:layout_gravity="center"/>

        <androidx.cardview.widget.CardView
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:layout_marginBottom="30dp"
                app:cardCornerRadius="75dp"
                app:cardBackgroundColor="#E0E0E0">

            <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_camera"
                    android:scaleType="centerCrop"/>
        </androidx.cardview.widget.CardView>

        <EditText
                android:id="@+id/inputPosition"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="League / Division"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

        <EditText
                android:id="@+id/inputAge"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Founded Year"
                android:inputType="number"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

        <EditText
                android:id="@+id/inputTeamCountry"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Country"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

        <EditText
                android:id="@+id/inputFoot"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Home Ground / City"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

        <EditText
                android:id="@+id/inputBudget"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Budget"
                android:inputType="number"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

        <EditText
                android:id="@+id/inputLookingFor"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Looking For (e.g. Striker)"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

        <EditText
                android:id="@+id/inputColors"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Team Colors"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

        <EditText
                android:id="@+id/inputRival"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Main Rival"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

        <EditText
                android:id="@+id/inputHonors"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Honors / Trophies"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:layout_marginBottom="30dp"/>

        <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Confirm Club Info"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_primary"
                android:layout_marginBottom="10dp"/>

        <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:backgroundTint="@color/whistle_red"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="50dp"/>

    </LinearLayout>
</ScrollView>